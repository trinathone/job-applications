# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://jam:jam@localhost:5432/jam
DATABASE_URL_SYNC=postgresql://jam:jam@localhost:5432/jam   # alembic only

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=db+postgresql://jam:jam@localhost:5432/jam

# ── Claude / Anthropic ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_DAILY_BUDGET_USD=5.00
CLAUDE_EXTRACTION_MODEL=claude-haiku-4-5-20251001

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
LOG_LEVEL=INFO

# ── API Sources ───────────────────────────────────────────────────────────────
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
REED_API_KEY=
THE_MUSE_API_KEY=

# ── Notifications ─────────────────────────────────────────────────────────────
